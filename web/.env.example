# =============================================================================
# Neckarstücke — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored; NEVER commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Service role key — only needed server-side (webhook handler). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# -----------------------------------------------------------------------------
# Stripe
# Use test keys (sk_test_… / pk_test_…) locally; live keys only on production.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Stripe Price IDs — one per print variant SKU
# Key format: STRIPE_PRICE_<SLUG>__<SIZE>__<FORMAT>  (uppercase, hyphens)
# Run `pnpm stripe:seed` to create these and auto-populate .env.local.
#
# Collection 01 — Minneburg (NS-01)
# -----------------------------------------------------------------------------
STRIPE_PRICE_MINNEBURG__30X40-CM__PRINT=price_...
STRIPE_PRICE_MINNEBURG__30X40-CM__FRAMED=price_...
STRIPE_PRICE_MINNEBURG__50X70-CM__PRINT=price_...
STRIPE_PRICE_MINNEBURG__50X70-CM__FRAMED=price_...
STRIPE_PRICE_MINNEBURG__70X100-CM__PRINT=price_...

# Collection 01 — Dilsberg (NS-02)
STRIPE_PRICE_DILSBERG__30X40-CM__PRINT=price_...
STRIPE_PRICE_DILSBERG__30X40-CM__FRAMED=price_...
STRIPE_PRICE_DILSBERG__50X70-CM__PRINT=price_...
STRIPE_PRICE_DILSBERG__50X70-CM__FRAMED=price_...
STRIPE_PRICE_DILSBERG__70X100-CM__PRINT=price_...

# Collection 01 — Hirschhorn (NS-03)
STRIPE_PRICE_HIRSCHHORN__30X40-CM__PRINT=price_...
STRIPE_PRICE_HIRSCHHORN__30X40-CM__FRAMED=price_...
STRIPE_PRICE_HIRSCHHORN__50X70-CM__PRINT=price_...
STRIPE_PRICE_HIRSCHHORN__50X70-CM__FRAMED=price_...
STRIPE_PRICE_HIRSCHHORN__70X100-CM__PRINT=price_...

# Collection 01 — Heidelberg (NS-04)
STRIPE_PRICE_HEIDELBERG__30X40-CM__PRINT=price_...
STRIPE_PRICE_HEIDELBERG__30X40-CM__FRAMED=price_...
STRIPE_PRICE_HEIDELBERG__50X70-CM__PRINT=price_...
STRIPE_PRICE_HEIDELBERG__50X70-CM__FRAMED=price_...
STRIPE_PRICE_HEIDELBERG__70X100-CM__PRINT=price_...

# -----------------------------------------------------------------------------
# POD Supplier — Prodigi
# Sandbox key starts with sandbox_ ; production key starts with live_
# See docs/pod-supplier-decision.md for integration spec.
# -----------------------------------------------------------------------------
PRODIGI_API_KEY=sandbox_...
# Webhook signing secret (from Prodigi dashboard → Webhooks)
PRODIGI_WEBHOOK_SECRET=whsec_prodigi_...
